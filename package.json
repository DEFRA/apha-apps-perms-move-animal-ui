{
  "name": "apha-apps-perms-move-animal-ui",
  "version": "0.0.0",
  "description": "Move animals under disease control restrictions frontend",
  "sideEffects": false,
  "main": ".server/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=10.9.0 <11.6.4"
  },
  "scripts": {
    "build": "run-s build:frontend build:server",
    "build:frontend": "NODE_ENV=production webpack",
    "build:server": "NODE_ENV=production babel --delete-dir-on-start --ignore \"**/*.test.js\" --ignore \"**/test-helpers\" --copy-files --no-copy-ignored --out-dir ./.server ./src",
    "dev": "run-p frontend:watch server:watch",
    "dev:debug": "export SESSION_CACHE_ENGINE=redis && run-p frontend:watch server:debug",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js,njk}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js,njk}\"",
    "frontend:watch": "NODE_ENV=development webpack --watch",
    "template-check": "./template-check.sh",
    "git:pre-commit-hook": "npm run template-check && npm run format:check && npm run lint && npm run test:changed",
    "postinstall": "npm run setup:husky && npm run build",
    "lint": "run-s lint:js lint:scss lint:types",
    "lint:fix": "eslint . --fix",
    "lint:js": "eslint .",
    "lint:types": "tsc --build tsconfig.json",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "postversion": "git add package.json package-lock.json && git commit -m $npm_package_version",
    "test": "jest --coverage --verbose",
    "test:changed": "npm run test -- --changedSince=origin/main",
    "test:watch": "jest --watch",
    "server:watch": "nodemon --exec tsx --enable-source-maps ./src -e njk,js",
    "server:debug": "nodemon --exec tsx --enable-source-maps --inspect ./src -e njk,js",
    "prestart": "npm run build",
    "start": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "user-journey-test": "npm run user-journey-test:js",
    "user-journey-test:js": "wdio run ./user-journey-tests/TB/wdioJS.conf.js",
    "user-journey-test:nojs": "wdio run ./user-journey-tests/TB/wdioNoJS.conf.js",
    "user-journey-test:bs": "wdio run ./user-journey-tests/TB/wdio.browserstack.conf.js",
    "user-journey-test:bs-extended-desktop": "wdio run ./user-journey-tests/TB/wdio.browserstack.extended-desktop.conf.js",
    "user-journey-test:bs-extended-mobile": "wdio run ./user-journey-tests/TB/wdio.browserstack.extended-mobile.conf.js",
    "exotics-journey-test": "wdio run ./user-journey-tests/exotics/wdioExotics.conf.js",
    "fmd-journey-test": "wdio run ./user-journey-tests/fmd/wdioFMD.conf.js"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-s3": "3.999.0",
    "@babel/runtime": "^7.25.6",
    "@date-fns/tz": "1.2.0",
    "@defra/forms-engine-plugin": "4.0.24",
    "@elastic/ecs-pino-format": "^1.5.0",
    "@hapi/bell": "13.1.0",
    "@hapi/catbox-memory": "^6.0.2",
    "@hapi/catbox-redis": "^7.0.2",
    "@hapi/cookie": "12.0.1",
    "@hapi/crumb": "9.0.1",
    "@hapi/hapi": "^21.4.8",
    "@hapi/inert": "^7.1.0",
    "@hapi/jwt": "3.2.0",
    "@hapi/vision": "^7.0.3",
    "@hapi/yar": "^11.0.2",
    "accessible-autocomplete": "3.0.1",
    "aws-embedded-metrics": "^4.1.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "convict": "^6.2.5",
    "cssnano": "^7.0.6",
    "cssnano-preset-default": "^7.0.6",
    "date-fns": "4.1.0",
    "govuk-frontend": "^5.13.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "^3.0.1",
    "https-proxy-agent": "^7.0.5",
    "ioredis": "^5.4.1",
    "lodash": "^4.18.1",
    "node-fetch": "^3.3.2",
    "nunjucks": "^3.2.4",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "proxy-agent": "6.5.0",
    "sharp": "0.33.5",
    "undici": "6.24.1",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/register": "7.29.7",
    "@types/convict": "^6.1.6",
    "@types/hapi__catbox-memory": "^6.0.2",
    "@types/hapi__crumb": "7.3.7",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "25.9.1",
    "@types/nunjucks": "^3.2.6",
    "@types/webpack-assets-manifest": "^5.1.4",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@wdio/browserstack-service": "9.27.2",
    "@wdio/cli": "9.27.2",
    "@wdio/globals": "9.27.2",
    "@wdio/local-runner": "9.27.2",
    "@wdio/mocha-framework": "9.27.2",
    "@wdio/spec-reporter": "9.27.2",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-module-resolver": "5.0.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "cheerio": "^1.2.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "deepmerge": "4.3.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jest-formatting": "^3.1.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-wdio": "9.27.2",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jsdom": "29.1.1",
    "nock": "^14.0.15",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "postcss-load-config": "^6.0.1",
    "postcss-loader": "^8.2.1",
    "prettier": "3.8.3",
    "prettier-plugin-jinja-template": "2.2.0",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^17.0.0",
    "source-map-loader": "^5.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-gds": "^2.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "webpack": "^5.94.0",
    "webpack-assets-manifest": "^6.5.2",
    "webpack-cli": "^7.0.3"
  }
}
